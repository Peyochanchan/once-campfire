<% @page_title = t("invitations.accept_title") %>

<section class="txt-align-center">
  <div class="panel">
    <%= account_logo_tag style: "center margin-block-end txt-xx-large" %>

    <h1 class="txt-large margin-none-block-start">
      <%= t("invitations.accept_heading", app_name: app_name) %>
    </h1>
    <p class="txt-subtle margin-block">
      <%= t("invitations.accept_body", inviter: @invitation.invited_by.name) %>
    </p>

    <%= form_with model: @user, url: accept_invitation_path(@invitation.token), class: "flex flex-column gap" do |form| %>
      <% if @user.errors.any? %>
        <div class="flash flash--negative">
          <% @user.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <label class="flex align-center gap input input--actor">
        <%= form.text_field :name, class: "input txt-large", placeholder: t("profile.name_placeholder"), required: true, autofocus: true %>
        <%= image_tag "person.svg", aria: { hidden: "true" }, size: 24, class: "colorize--black" %>
      </label>

      <label class="flex align-center gap input input--actor">
        <%= form.email_field :email_address, class: "input txt-large", value: @invitation.email, disabled: true %>
        <%= image_tag "email.svg", aria: { hidden: "true" }, size: 24, class: "colorize--black" %>
      </label>

      <label class="flex align-center gap input input--actor">
        <%= form.password_field :password, class: "input txt-large", placeholder: t("auth.password_placeholder"), required: true, minlength: 8, maxlength: 72 %>
        <%= image_tag "password.svg", aria: { hidden: "true" }, size: 24, class: "colorize--black" %>
      </label>

      <%= form.button class: "btn btn--reversed center txt-large", type: "submit" do %>
        <%= t("invitations.accept_submit") %>
      <% end %>
    <% end %>
  </div>
</section>
