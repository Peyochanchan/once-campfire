<% @page_title = "Verify your identity" %>
<% turbo_page_requires_reload %>

<section class="txt-align-center">
  <div class="panel <%= "shake" if flash[:alert] %>">
    <%= account_logo_tag style: "center margin-block-end txt-xx-large" %>

    <h2 class="txt-large margin-block-end"><%= t("auth.verify_email_title") %></h2>
    <p class="txt-subtle margin-block-end">
      We sent a 6-digit code to <strong><%= @pending_session.user.email_address %></strong>
    </p>

    <%= form_with url: confirm_session_path, method: :post, class: "flex flex-column gap", data: { turbo: false, controller: "otp-input" } do |form| %>
      <%= form.hidden_field :otp_code, data: { otp_input_target: "hidden" } %>

      <div class="otp-boxes">
        <% 6.times do %>
          <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" autocomplete="off" required
                 class="otp-box"
                 data-otp-input-target="digit"
                 data-action="input->otp-input#input keydown->otp-input#keydown paste->otp-input#paste">
        <% end %>
      </div>

      <%= form.button class: "btn btn--reversed center txt-large margin-block-start", type: "submit" do %>
        <%= t("auth.verify_button") %>
      <% end %>
    <% end %>

    <p class="txt-small txt-subtle margin-block-start">
      <%= t("auth.code_expiry") %>.
      <%= link_to t("auth.back_to_signin"), new_session_path %>
    </p>
  </div>
</section>
